.env
__pycache__/
*.pyc
data/paper_trades/
engine/target/
*.so
*.dylib
*.whl

# Bar cache (Alpaca minute bars cached for replay experiments)
data/bar_cache/

# Generated tearsheet reports
reports/

# SQLite databases
data/journal/*.db
data/journal/*.db-wal
data/journal/*.db-shm

# Engine logs (append-mode, local only)
data/journal/engine.log
data/journal/engine.log.*
data/journal/walkforward.log

# Generated dashboards (regenerated by scripts/)
dashboards/*.html

# Pattern analysis logs
data/journal/patterns.log

# Bar data (too large for git — backfilled locally from Alpaca API)
data/experiment_bars*.json
data/active_pairs_v*.json

# Runner output and dashboard data (regenerated on each run)
data/order_intents.json
data/trade_results.json
data/backtest_history.json
data/dashboard_data.json
data/daily_pnl.json

# Pair picker intermediate files
data/pair_picker_output.json
data/pair_picker_prices.json
data/pair_picker_*.lock
data/thompson_state.json

# Simulation results (regenerated)
data/sim_*_results.json
data/walk_forward_results.json

# Claude working files
.claude/scheduled_tasks.lock
.claude/worktrees/

# Virtual environments
.venv/
